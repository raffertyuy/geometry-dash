{
  "name": "the-real-geometry-dash",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Subway-Surfers-style endless runner where obstacles are geometry-question gates.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@types/node": "^22.0.0",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
